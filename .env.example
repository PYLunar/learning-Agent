# LLM Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000

# Set to true to use mock responses (no API key needed)
MOCK_MODE=false

# ========== Real API Keys ==========
# 天气 API（和风天气 - 中国用户首选，免费注册: https://dev.qweather.com）
# 开发版 1000 次/天，支持中文城市名直接查询
QWEATHER_KEY=your_qweather_key

# 天气 API（OpenWeatherMap - 国际备用，免费注册: https://openweathermap.org/api）
WEATHER_API_KEY=your_openweather_api_key

# 地图 API（高德地图 - 中国用户首选，免费注册: https://lbs.amap.com）
# 个人开发者 5000 次/天，支持中文地址解析和中国境内路线规划
AMAP_KEY=your_amap_key

# 地图 API（Google Maps - 国际备用）
GOOGLE_MAPS_API_KEY=

# 航班 API（免费注册: https://developers.amadeus.com）
AMADEUS_API_KEY=your_amadeus_api_key
AMADEUS_API_SECRET=your_amadeus_api_secret

# 酒店 API（可选）
BOOKING_API_KEY=

# ========== 搜索 API（可选，有免费回退） ==========
# Google 搜索 API（可选）
GOOGLE_SEARCH_API_KEY=
GOOGLE_SEARCH_CX=

# Bing 搜索 API（Azure Cognitive Services，中国用户更稳定）
BING_SEARCH_API_KEY=

# ========== 免费联网功能（无需 API Key） ==========
# Wikipedia（免费）
WIKIPEDIA_ENABLED=true

# ========== 缓存与重试 ==========
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
MAX_RETRIES=3
RETRY_DELAY_SECONDS=1.0

# ========== 应用设置 ==========
LOG_LEVEL=INFO
DEFAULT_ORIGIN=Beijing
DEFAULT_LANGUAGE=zh
